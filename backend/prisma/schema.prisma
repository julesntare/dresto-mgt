generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model User {
    id        String   @id @default(cuid())
    email     String?  @unique
    phone     String?
    password  String
    name      String
    role      UserRole @default(STAFF)
    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    orders Order[]

    @@map("users")
}

model Category {
    id          String   @id @default(cuid())
    name        String
    description String?
    isActive    Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    // Relations
    menuItems MenuItem[]

    @@map("categories")
}

model MenuItem {
    id          String   @id @default(cuid())
    name        String
    description String?
    price       Decimal  @db.Decimal(10, 2)
    image       String?
    isAvailable Boolean  @default(true)
    ingredients String[]
    categoryId  String
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    // Relations
    category   Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
    orderItems OrderItem[]

    @@map("menu_items")
}

model Table {
    id        String      @id @default(cuid())
    number    String      @unique
    capacity  Int
    location  String?
    status    TableStatus @default(AVAILABLE)
    isActive  Boolean     @default(true)
    createdAt DateTime    @default(now())
    updatedAt DateTime    @updatedAt

    // Relations
    orders Order[]

    @@map("tables")
}

model Order {
    id            String      @id @default(cuid())
    orderNumber   String      @unique
    accessToken       String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    guestSessionToken String?
    customerName      String?
    customerPhone     String?
    totalAmount       Decimal     @db.Decimal(10, 2)
    status            OrderStatus @default(PENDING)
    orderType         OrderType   @default(DINE_IN)
    tableId           String?
    notes             String?
    userId            String?
    transactionId     String?
    paymentStatus     PaymentStatus @default(UNPAID)
    paymentProvider   String?
    paidAt            DateTime?
    createdAt     DateTime    @default(now())
    updatedAt     DateTime    @updatedAt

    // Relations
    user       User?          @relation(fields: [userId], references: [id])
    table      Table?         @relation(fields: [tableId], references: [id])
    orderItems OrderItem[]
    messages   OrderMessage[]

    @@map("orders")
}

model OrderMessage {
    id         String     @id @default(cuid())
    orderId    String
    order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
    content    String
    senderType SenderType
    senderName String?
    isRead     Boolean    @default(false)
    createdAt  DateTime   @default(now())

    @@map("order_messages")
}

model OrderItem {
    id                  String   @id @default(cuid())
    quantity            Int
    price               Decimal  @db.Decimal(10, 2)
    excludedIngredients String[]
    orderId             String
    menuItemId          String
    createdAt           DateTime @default(now())

    // Relations
    order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
    menuItem MenuItem @relation(fields: [menuItemId], references: [id])

    @@map("order_items")
}

model Restaurant {
    id              String   @id @default(cuid())
    name            String
    logoUrl         String?
    themeColor      String?  @default("#000000")
    currency        String   @default("RWF")
    languages       String[] @default(["en"])

    // Channel toggles — a bar with no kitchen turns off delivery; a ghost kitchen turns off dine-in
    dineInEnabled   Boolean  @default(true)
    takeawayEnabled Boolean  @default(true)
    deliveryEnabled Boolean  @default(false)

    // Money rules
    serviceChargePct Decimal? @db.Decimal(5, 2)
    vatEnabled       Boolean  @default(false)
    vatPct           Decimal? @db.Decimal(5, 2)
    deliveryFee      Decimal? @db.Decimal(10, 2)
    deliveryMinOrder Decimal? @db.Decimal(10, 2)

    // Payment providers enabled (checkbox list in admin)
    momoEnabled      Boolean  @default(true)
    airtelEnabled    Boolean  @default(false)
    cardEnabled      Boolean  @default(false)
    cashEnabled      Boolean  @default(true)

    openingHours     Json?                           // per-day open/close; auto-close ordering when shut
    orderingBaseUrl  String?                          // base URL customer ordering QR codes point to
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt

    @@map("restaurant")
}

enum UserRole {
    ADMIN
    MANAGER
    STAFF
    CUSTOMER
}

enum SenderType {
    CLIENT
    STAFF
}

enum OrderStatus {
    PENDING
    CONFIRMED
    PREPARING
    READY
    DELIVERED
    CANCELLED
}

enum OrderType {
    DINE_IN
    TAKEAWAY
    DELIVERY
}

enum TableStatus {
    AVAILABLE
    OCCUPIED
    RESERVED
}

enum PaymentStatus {
    UNPAID
    PENDING_VERIFICATION
    PAID
}
