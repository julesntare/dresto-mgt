generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model User {
    id        String   @id @default(cuid())
    email     String?  @unique
    phone     String?
    password  String
    name      String
    role      UserRole @default(STAFF)
    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    orders Order[]
    passwordResetTokens PasswordResetToken[]

    @@map("users")
}

model PasswordResetToken {
    id        String    @id @default(cuid())
    userId    String
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    tokenHash String    @unique
    expiresAt DateTime
    usedAt    DateTime?
    createdAt DateTime  @default(now())

    @@map("password_reset_tokens")
}

model Category {
    id          String   @id @default(cuid())
    name        String
    description String?
    isActive    Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    // Relations
    menuItems MenuItem[]

    @@map("categories")
}

model MenuItem {
    id          String   @id @default(cuid())
    name        String
    description String?
    price       Decimal  @db.Decimal(10, 2)
    image       String?
    isAvailable Boolean  @default(true)
    ingredients String[]
    categoryId  String
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    // Relations
    category       Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
    orderItems     OrderItem[]
    modifierGroups ModifierGroup[]

    @@map("menu_items")
}

model Table {
    id        String      @id @default(cuid())
    number    String      @unique
    capacity  Int
    location  String?
    status    TableStatus @default(AVAILABLE)
    isActive  Boolean     @default(true)
    createdAt DateTime    @default(now())
    updatedAt DateTime    @updatedAt

    // Relations
    orders Order[]

    @@map("tables")
}

model Order {
    id            String      @id @default(cuid())
    orderNumber   String      @unique
    accessToken       String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    guestSessionToken String?
    customerName      String?
    customerPhone     String?
    totalAmount       Decimal     @db.Decimal(10, 2)
    status            OrderStatus @default(PENDING)
    orderType         OrderType   @default(DINE_IN)
    tableId           String?
    notes             String?
    userId            String?
    transactionId     String?
    paymentStatus     PaymentStatus @default(UNPAID)
    paymentProvider   String?
    paidAt            DateTime?

    // Delivery (orderType = DELIVERY) — §4.2-2
    deliveryAddress   String?
    deliveryLat       Float?
    deliveryLng       Float?
    deliveryFee       Decimal?  @db.Decimal(10, 2)
    deliveryZone      String?
    riderId           String?

    // Fulfillment leg, separate from prep status — §4.2-3
    // Kitchen board reads `status`; delivery/service board reads `fulfillmentStatus`.
    fulfillmentStatus FulfillmentStatus @default(NONE)

    createdAt     DateTime    @default(now())
    updatedAt     DateTime    @updatedAt

    // Relations
    user          User?          @relation(fields: [userId], references: [id])
    table         Table?         @relation(fields: [tableId], references: [id])
    orderItems    OrderItem[]
    messages      OrderMessage[]
    paymentEvents PaymentEvent[]

    @@map("orders")
}

model OrderMessage {
    id         String     @id @default(cuid())
    orderId    String
    order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
    content    String
    senderType SenderType
    senderName String?
    isRead     Boolean    @default(false)
    createdAt  DateTime   @default(now())

    @@map("order_messages")
}

model OrderItem {
    id                  String   @id @default(cuid())
    quantity            Int
    price               Decimal  @db.Decimal(10, 2)
    excludedIngredients String[]
    orderId             String
    menuItemId          String
    createdAt           DateTime @default(now())

    // Relations
    order             Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
    menuItem          MenuItem           @relation(fields: [menuItemId], references: [id])
    selectedModifiers SelectedModifier[]

    @@map("order_items")
}

// Paid modifiers / add-ons — §4.2-4
model ModifierGroup {
    id         String     @id @default(cuid())
    menuItemId String
    menuItem   MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
    name       String // "Size", "Extras"
    minSelect  Int        @default(0)
    maxSelect  Int        @default(1)
    options    Modifier[]
    createdAt  DateTime   @default(now())
    updatedAt  DateTime   @updatedAt

    @@map("modifier_groups")
}

model Modifier {
    id          String        @id @default(cuid())
    groupId     String
    group       ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
    name        String // "Large", "Double shot"
    priceDelta  Decimal       @default(0) @db.Decimal(10, 2)
    isAvailable Boolean       @default(true)
    createdAt   DateTime      @default(now())
    updatedAt   DateTime      @updatedAt

    @@map("modifiers")
}

// Snapshot of selected modifiers at order time (same reasoning as OrderItem.price snapshot)
model SelectedModifier {
    id          String    @id @default(cuid())
    orderItemId String
    orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
    name        String
    priceDelta  Decimal   @db.Decimal(10, 2)
    createdAt   DateTime  @default(now())

    @@map("selected_modifiers")
}

// Payment provider event log — idempotency for async webhooks (§7; provider wiring on hold)
model PaymentEvent {
    id          String   @id @default(cuid())
    orderId     String
    order       Order    @relation(fields: [orderId], references: [id])
    provider    String // "paypack" | "irembopay"
    providerRef String   @unique // idempotency key from provider
    status      String // provider-reported status
    amount      Decimal  @db.Decimal(10, 2)
    rawPayload  Json?
    createdAt   DateTime @default(now())

    @@map("payment_events")
}

model Restaurant {
    id              String   @id @default(cuid())
    name            String
    logoUrl         String?
    themeColor      String?  @default("#000000")
    currency        String   @default("RWF")
    languages       String[] @default(["en"])

    // Channel toggles — a bar with no kitchen turns off delivery; a ghost kitchen turns off dine-in
    dineInEnabled   Boolean  @default(true)
    takeawayEnabled Boolean  @default(true)
    deliveryEnabled Boolean  @default(false)

    // Money rules
    serviceChargePct Decimal? @db.Decimal(5, 2)
    vatEnabled       Boolean  @default(false)
    vatPct           Decimal? @db.Decimal(5, 2)
    deliveryFee      Decimal? @db.Decimal(10, 2)
    deliveryMinOrder Decimal? @db.Decimal(10, 2)

    // Payment providers enabled (checkbox list in admin)
    momoEnabled      Boolean  @default(true)
    airtelEnabled    Boolean  @default(false)
    cardEnabled      Boolean  @default(false)
    cashEnabled      Boolean  @default(true)

    openingHours     Json?                           // per-day open/close; auto-close ordering when shut
    orderingBaseUrl  String?                          // base URL customer ordering QR codes point to
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt

    @@map("restaurant")
}

enum UserRole {
    ADMIN
    MANAGER
    STAFF
    CUSTOMER
}

enum SenderType {
    CLIENT
    STAFF
}

enum OrderStatus {
    PENDING
    CONFIRMED
    PREPARING
    READY
    DELIVERED
    CANCELLED
}

enum OrderType {
    DINE_IN
    TAKEAWAY
    DELIVERY
}

enum TableStatus {
    AVAILABLE
    OCCUPIED
    RESERVED
}

enum PaymentStatus {
    UNPAID
    PENDING_VERIFICATION
    PAID
}

enum FulfillmentStatus {
    NONE
    AWAITING_PICKUP
    OUT_FOR_DELIVERY
    DELIVERED
    SERVED
}
